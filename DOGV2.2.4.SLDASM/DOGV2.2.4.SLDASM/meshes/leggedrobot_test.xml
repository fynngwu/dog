<mujoco model="Legged_Robot">
  <compiler angle="radian" autolimits="true" eulerseq="zyx"/>
  <option timestep='0.001' iterations='100' solver='PGS' gravity='0 0 -9.81'>  
    <flag frictionloss="enable"/>
  </option>
  <size njmax="500" nconmax="100" />

