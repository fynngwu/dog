          </body>
        </body>
      </body>

      <body name="RR_HipA_link" pos="-0.16 -0.0675 0.063" quat="0.5 0.5 -0.5 -0.5">
        <joint name="RR_HipA_joint" axis="0 0 1" range="-0.7853982 0.7853982" class="leg_joint_param"/>
