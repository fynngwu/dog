    <mesh name="LR_Foot_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/LR_Foot_link.STL"/>
    <mesh name="RF_HipA_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/RF_HipA_link.STL"/>
    <mesh name="RF_HipF_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/RF_HipF_link.STL"/>
    <mesh name="RF_Knee_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/RF_Knee_link.STL"/>
    <mesh name="RF_Foot_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/RF_Foot_link.STL"/>
    <mesh name="RR_HipA_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/RR_HipA_link.STL"/>
    <mesh name="RR_HipF_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/RR_HipF_link.STL"/>
    <mesh name="RR_Knee_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/RR_Knee_link.STL"/>
