    <motor ctrllimited='true'/>
    <geom condim='4' contype="1" conaffinity="15" solref='0.001 2' friction='0.9 0.2 0.2'/>
    <default class='leg_joint_param'>
      <joint damping="0.5" frictionloss="0.01" armature="0.01"/>
    </default>
  </default>

  <asset>
    <mesh name="base_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/base_link.STL"/>
    <mesh name="LF_HipA_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/LF_HipA_link.STL"/>
    <mesh name="LF_HipF_link" file="/home/ares/Desktop/DOGV2.2.4.SLDASM/DOGV2.2.4.SLDASM/meshes/LF_HipF_link.STL"/>
